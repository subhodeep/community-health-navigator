# Base URL of the API service (Cloud Run). Defaults to http://localhost:8080 when unset.
VITE_API_URL=http://localhost:8080

# Optional: Firebase web app config as a single-line JSON string.
# When set, the app uses Firebase anonymous auth and sends Authorization: Bearer <idToken>.
# When unset, the app runs in demo mode (X-Demo-User / X-Persona headers).
# VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","appId":"..."}
